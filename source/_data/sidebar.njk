{# ======================
   NexT 兼容版 文章系列组件
   系列间：字典序排序
   系列内：按 series_order 自定义顺序
====================== #}

{% set seriesList = {} %}

{% for post in site.posts.toArray() %}
  {% if post.series and post.series.trim() %}
    {% set sName = post.series.trim() %}
    {% if not seriesList[sName] %}
      {% set _ = seriesList.__setitem__(sName, []) %}
    {% endif %}
    {% set _ = seriesList[sName].push(post) %}
  {% endif %}
{% endfor %}

{% set seriesNames = seriesList | keys | sort %}

{% if seriesNames.length > 0 %}
<div class="widget-wrap">
  <h3 class="widget-title">
    <i class="fa fa-folder-open fa-fw"></i> 文章系列
  </h3>
  <div class="widget-content">
    <ul class="series-list" style="list-style: none; padding: 0; margin: 0;">
      {% for name in seriesNames %}
        <li class="series-item" style="margin: 8px 0;">
          <span style="font-weight: 700; color: #49b1f5; font-size: 14px;">{{ name }}</span>
          <ul class="series-posts" style="list-style: none; padding: 4px 0 0 16px; margin: 4px 0;">
            {% set posts = seriesList[name] | sort(attribute='series_order', default=999) %}
            {% for post in posts %}
              <li style="margin: 4px 0; font-size: 13px;">
                <a href="{{ url_for(post.path) }}" style="color: #666; transition: color 0.3s;">
                  {{ post.title }}
                </a>
              </li>
            {% endfor %}
          </ul>
        </li>
      {% endfor %}
    </ul>
  </div>
</div>
{% endif %}